datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  password String
  role String
  records Record[]
}

model Record {
  id Int @id @default(autoincrement())
  userId Int
  type String
  amount Float
  category String
  date DateTime
  notes String?
  isDeleted Boolean @default(false)

  user User @relation(fields:[userId],references:[id])
}